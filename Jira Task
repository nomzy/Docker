app/models.py — Defines the Property data model using Pydantic:
from pydantic import BaseModel

class Property(BaseModel):
    address: str
    bedrooms: int
    bathrooms: int
    square_feet: float
    location_score: float
    year_built: int

app/main.py — FastAPI application with two endpoints:
from fastapi import FastAPI
from app.models import Property
import os

app = FastAPI(title="WDTech Property Valuation API")

BASE_PRICE_PER_SQFT = float(os.getenv("BASE_PRICE_PER_SQFT", "150"))
API_ENV = os.getenv("APP_ENV", "development")

@app.get("/health")
def health():
    return {"status": "ok", "env": API_ENV}

@app.post("/valuate")
def valuate_property(property: Property):
    base_value = property.square_feet * BASE_PRICE_PER_SQFT
    bedroom_bonus = property.bedrooms * 10000
    bathroom_bonus = property.bathrooms * 5000
    location_multiplier = 1 + (property.location_score / 100)
    age_penalty = max(0, (2024 - property.year_built)) * 200
    estimated_value = (base_value + bedroom_bonus + bathroom_bonus) * location_multiplier - age_penalty

    return {
        "address": property.address,
        "estimated_value": round(estimated_value, 2),
        "currency": "USD",
        "env": API_ENV
    }
```

